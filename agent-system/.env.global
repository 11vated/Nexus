# ============================================================
# GLOBAL ENVIRONMENT FOR ALL AI AGENTS
# Set these in your system environment
# ============================================================

# ============================================================
# OLLAMA (Local LLM - NO API KEY NEEDED!)
# ============================================================
OLLAMA_HOST=http://localhost:11434
OPENAI_API_KEY=local

# ============================================================
# OPENAI (ChatGPT, etc.)
# ============================================================
# OPENAI_API_KEY=sk-your-key-here

# ============================================================
# ANTHROPIC (Claude)
# ============================================================
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================================
# GITHUB
# ============================================================
# Create token at: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here

# ============================================================
# DATABASES
# ============================================================
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# ============================================================
# SLACK
# ============================================================
# Create app at: https://api.slack.com/apps
# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_TEAM_ID=your-team-id

# ============================================================
# NOTION
# ============================================================
# Get from: https://www.notion.so/my-integrations
# NOTION_API_KEY=secret_your_key

# ============================================================
# LINEAR (Issue Tracking)
# ============================================================
# Get from: https://linear.app/settings/api
# LINEAR_API_KEY=lin_your_key

# ============================================================
# BRAVE SEARCH (Free tier available!)
# ============================================================
# Get from: https://brave.com/search/api/
# BRAVE_API_KEY=your_brave_key

# ============================================================
# TAVILY (AI Search)
# ============================================================
# Get from: https://tavily.com/
# TAVILY_API_KEY=your_key

# ============================================================
# SENTRY (Error Tracking - Free tier!)
# ============================================================
# Get from: https://sentry.io/settings/
# SENTRY_AUTH_TOKEN=your_token

# ============================================================
# FIGMA
# ============================================================
# Get from: Figma > Settings > Personal Access Tokens
# FIGMA_ACCESS_TOKEN=your_token

# ============================================================
# AWS
# ============================================================
# AWS_ACCESS_KEY_ID=your_key_id
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_REGION=us-east-1

# ============================================================
# AZURE
# ============================================================
# AZURE_SUBSCRIPTION_ID=your_sub_id
# AZURE_CLIENT_ID=your_client_id
# AZURE_CLIENT_SECRET=your_secret
# AZURE_TENANT_ID=your_tenant_id

# ============================================================
# CLOUDFLARE
# ============================================================
# Get from: https://dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_API_TOKEN=your_token
# CLOUDFLARE_ACCOUNT_ID=your_account_id