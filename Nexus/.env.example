# Nexus Configuration
# Copy this to .env and fill in your values

# Paths
WORKSPACE_ROOT=C:/Users/11vat/Desktop/Copilot/Aider-Local-llm-agent/workspace
TOOLS_DIR=C:/Users/11vat/Desktop/Copilot/Aider-Local-llm-agent/tools
LOGS_DIR=C:/Users/11vat/Desktop/Copilot/Aider-Local-llm-agent/logs

# Tool Paths (leave empty to search PATH)
OPENCODE_PATH=
AIDER_PATH=
GOOSE_PATH=

# Model Configuration
DEFAULT_MODEL=qwen2.5-coder:14b
OLLAMA_URL=http://localhost:11434
MODEL_TIMEOUT_SECONDS=120

# Security (32-byte base64 key for encrypting API keys)
# Generate with: python -c "import base64; print(base64.b64encode(os.urandom(32)).decode())"
API_KEYS_ENCRYPTION_KEY=

# Operational
LOG_LEVEL=INFO
MAX_CONCURRENT_TOOLS=4
ENABLE_TELEMETRY=false