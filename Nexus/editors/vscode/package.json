{
  "name": "nexus-ai",
  "displayName": "Nexus AI",
  "description": "AI coding assistant with local LLM support — chat, autonomous agents, and code generation",
  "version": "0.6.0",
  "publisher": "nexus-ai",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nexus.openChat",
        "title": "Nexus: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "nexus.runAgent",
        "title": "Nexus: Run Autonomous Agent"
      },
      {
        "command": "nexus.showHardware",
        "title": "Nexus: Show Hardware Recommendations"
      },
      {
        "command": "nexus.toggleTheme",
        "title": "Nexus: Toggle Theme"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nexus",
          "title": "Nexus AI",
          "icon": "$(brain)"
        }
      ]
    },
    "views": {
      "nexus": [
        {
          "type": "webview",
          "id": "nexus.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "Nexus AI",
      "properties": {
        "nexus.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama API URL"
        },
        "nexus.model": {
          "type": "string",
          "default": "qwen2.5-coder:7b",
          "description": "Default model for chat"
        },
        "nexus.codingModel": {
          "type": "string",
          "default": "qwen2.5-coder:14b",
          "description": "Model for code generation"
        },
        "nexus.workspace": {
          "type": "string",
          "default": ".",
          "description": "Workspace directory for Nexus"
        },
        "nexus.theme": {
          "type": "string",
          "enum": ["dark", "light"],
          "default": "dark",
          "description": "Nexus UI theme"
        },
        "nexus.autoRouting": {
          "type": "boolean",
          "default": true,
          "description": "Automatically route tasks to optimal models based on hardware"
        }
      }
    },
    "keybindings": [
      {
        "command": "nexus.openChat",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}
